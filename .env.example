# GitHub
GITHUB_TOKEN=ghp_xxx
GITHUB_REPOS=owner/repo1,owner/repo2

# Plane.so
PLANE_API_KEY=xxx
PLANE_WORKSPACE=your-workspace
PLANE_EMAIL=your@email.com
PLANE_PROJECT_ID=your-project-uuid

# Kubernetes (use in-cluster config or ~/.kube/config)
# K8S_CONTEXTS=prod-project-1,prod-project-2  # comma-separated contexts; omit to use default
# K8S_NAMESPACES=cert-manager,kube-system     # comma-separated namespaces to show; omit to show all

# Backend port
PORT=3001
